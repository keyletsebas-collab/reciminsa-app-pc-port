  "description": "Aplicacion de escritorio para la gestion de materiales reciclables en RECIMINSA.",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "node build.js",
    "clean": "node -e \"const fs=require('fs'); ['www','out'].forEach(d=>fs.existsSync(d)&&fs.rmSync(d,{recursive:true,force:true})); console.log('🧹 Carpetas www y out eliminadas.');\""
  },
